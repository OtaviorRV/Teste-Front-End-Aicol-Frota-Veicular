# Este projeto usa Angular environments (src/environments/) para configuração.
# Não há variáveis lidas via process.env em runtime.
#
# Para trocar o ambiente, use os scripts do package.json:
#
#   npm start           → mock (sem backend, dados de public/assets/mocks/)
#   npm run start:api   → backend local em http://localhost:3000
#   npm run build       → produção (https://api.aivacol.com)
#
# Para customizar endpoints, edite diretamente:
#   src/environments/environment.development.ts  → apiUrl
#   src/environments/environment.prod.ts         → apiUrl

API_URL=http://localhost:3000
